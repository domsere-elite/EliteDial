generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  // PK is auth.users.id (Supabase generates the UUID; DB-level FK enforces it).
  id           String   @id @db.Uuid
  email        String   @unique
  firstName    String
  lastName     String
  role         String   @default("agent") // agent | supervisor | admin
  status       String   @default("offline") // available | break | offline | on-call
  extension    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  calls        Call[]
  callSessions CallSession[]
  voicemails   Voicemail[]
  campaigns    Campaign[]
  powerDialBatches PowerDialBatch[]
}

model Call {
  id             String   @id @default(uuid())
  provider       String   @default("signalwire") // signalwire | retell | mock
  channel        String   @default("human") // human | ai
  mode           String   @default("manual") // manual | preview | progressive | predictive | ai_outbound | inbound
  direction      String   // inbound | outbound
  fromNumber     String
  toNumber       String
  status         String   @default("initiated") // initiated | ringing | in-progress | completed | failed | no-answer | busy | voicemail | blocked-precheck
  duration       Int      @default(0) // seconds
  recordingUrl   String?
  dispositionId  String?
  dispositionNote String?
  accountId      String?  // CRM account reference
  accountName    String?
  agentId        String?
  agent          Profile? @relation(fields: [agentId], references: [id])
  providerCallId String?
  signalwireCallId String?
  providerMetadata Json?
  fdcpaNotice    Boolean  @default(false) // was FDCPA notice played
  dncChecked     Boolean  @default(false) // was DNC checked before dial
  retellAgentPromptVersion  String?   // copied from Campaign at dial time
  precheckBlockedReasons    String?   // comma-separated reasons; null on successful dials
  createdAt      DateTime @default(now())
  completedAt    DateTime?

  campaignAttempts CampaignAttempt[]
  callSession      CallSession?
  events           CallEvent[]
  recordings       CallRecording[]
  transcripts      CallTranscript[]

  @@index([agentId])
  @@index([accountId])
  @@index([createdAt])
  @@index([status])
  @@index([provider, providerCallId])
  @@index([agentId, createdAt])
  @@index([direction, createdAt])
}

model CallSession {
  id                  String           @id @default(uuid())
  callId              String?          @unique
  call                Call?            @relation(fields: [callId], references: [id])
  provider            String           @default("signalwire")
  providerCallId      String?
  providerParentCallId String?
  channel             String           @default("human") // human | ai
  mode                String           @default("manual") // manual | preview | progressive | predictive | ai_outbound | inbound
  direction           String           // inbound | outbound
  fromNumber          String
  toNumber            String
  status              String           @default("initiated")
  accountId           String?
  accountName         String?
  leadExternalId      String?
  agentId             String?
  agent               Profile?         @relation(fields: [agentId], references: [id])
  campaignId          String?
  campaign            Campaign?        @relation(fields: [campaignId], references: [id])
  contactId           String?
  contact             CampaignContact? @relation(fields: [contactId], references: [id])
  crmContext          Json?
  providerMetadata    Json?
  startedAt           DateTime         @default(now())
  answeredAt          DateTime?
  completedAt         DateTime?
  lastEventAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  events              CallEvent[]
  recordings          CallRecording[]
  transcripts         CallTranscript[]

  @@unique([provider, providerCallId])
  @@index([agentId])
  @@index([accountId])
  @@index([campaignId])
  @@index([contactId])
  @@index([status])
  @@index([createdAt])
}

model CallEvent {
  id             String       @id @default(uuid())
  sessionId      String?
  session        CallSession? @relation(fields: [sessionId], references: [id])
  callId         String?
  call           Call?        @relation(fields: [callId], references: [id])
  provider       String?
  providerCallId String?
  type           String
  source         String
  status         String?
  idempotencyKey String?      @unique
  payload        Json?
  createdAt      DateTime     @default(now())

  @@index([sessionId, createdAt])
  @@index([callId, createdAt])
  @@index([provider, providerCallId])
  @@index([type, createdAt])
}

model CallRecording {
  id                String       @id @default(uuid())
  sessionId         String?
  session           CallSession? @relation(fields: [sessionId], references: [id])
  callId            String?
  call              Call?        @relation(fields: [callId], references: [id])
  provider          String
  providerRecordingId String?
  url               String
  archiveUrl        String?
  status            String       @default("available")
  duration          Int?
  metadata          Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([sessionId, createdAt])
  @@index([callId, createdAt])
  @@index([provider, providerRecordingId])
}

model CallTranscript {
  id                  String       @id @default(uuid())
  sessionId           String?
  session             CallSession? @relation(fields: [sessionId], references: [id])
  callId              String?
  call                Call?        @relation(fields: [callId], references: [id])
  provider            String
  providerTranscriptId String?
  sourceType          String       @default("recording") // recording | voicemail | ai
  status              String       @default("available")
  text                String
  summary             String?
  metadata            Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([sessionId, createdAt])
  @@index([callId, createdAt])
  @@index([provider, providerTranscriptId])
}

model Voicemail {
  id             String   @id @default(uuid())
  fromNumber     String
  toNumber       String
  audioUrl       String?
  transcription  String?
  duration       Int      @default(0)
  isRead         Boolean  @default(false)
  assignedToId   String?
  assignedTo     Profile? @relation(fields: [assignedToId], references: [id])
  createdAt      DateTime @default(now())

  @@index([assignedToId])
  @@index([isRead])
  @@index([assignedToId, isRead])
  @@index([createdAt])
}

model DNCEntry {
  id          String   @id @default(uuid())
  phoneNumber String   @unique
  reason      String?
  addedBy     String?
  createdAt   DateTime @default(now())

  @@index([phoneNumber])
}

model PhoneNumber {
  id              String   @id @default(uuid())
  number          String   @unique
  label           String?
  type            String   @default("local")    // local | toll-free | mobile
  areaCode        String?                       // NPA (e.g., "205")
  state           String?                       // 2-letter state code
  region          String?                       // geographic region key
  rateCenterLata  String?                       // LATA for rate-center matching
  assignedTo      String?                       // queue name or agent
  isActive        Boolean  @default(true)
  healthScore     Int      @default(100)        // 0-100, decays on spam reports
  cooldownUntil   DateTime?                     // temporarily benched if overused
  lastUsedAt      DateTime?
  totalCallsToday Int      @default(0)
  totalCallsWeek  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  didGroupMembers DIDGroupMember[]

  @@index([areaCode])
  @@index([state])
  @@index([region])
  @@index([isActive, healthScore])
  @@index([cooldownUntil])
}

model QueueConfig {
  id              String  @id @default(uuid())
  name            String  @unique
  holdTimeout     Int     @default(60) // seconds before overflow
  overflowAction  String  @default("voicemail") // voicemail | virtual-agent | continue-hold
  holdMusicUrl    String?
  maxQueueSize    Int     @default(10)
  isActive        Boolean @default(true)
}

model WebhookConfig {
  id        String   @id @default(uuid())
  url       String
  secret    String
  events    String   // comma-separated: call.answered,call.completed,disposition.submitted,voicemail.received
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model APIKey {
  id        String   @id @default(uuid())
  key       String   @unique
  label     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  lastUsed  DateTime?
}

model DispositionCode {
  id        String  @id @default(uuid())
  code      String  @unique
  label     String
  category  String  @default("general") // payment | promise | skip | general
  isActive  Boolean @default(true)
}

model Campaign {
  id                 String            @id @default(uuid())
  name               String
  description        String?
  status             String            @default("draft") // draft | active | paused | completed | archived
  dialMode           String            @default("manual") // manual | progressive | ai_autonomous
  timezone           String            @default("America/Chicago")
  maxAttemptsPerLead Int               @default(6)
  retryDelaySeconds  Int               @default(600)
  maxConcurrentCalls Int               @default(0)
  // Power-dial multiplier applied to available human agents in progressive mode.
  // 1.0 = strict 1:1 (default, current behaviour). >1 means multiple PSTN legs per agent
  // with first-answer-wins routing handled in Phase 2 of the power-dial work.
  dialRatio          Float             @default(1.0)
  // Behaviour when SWML detect_machine reports a machine/voicemail.
  // hangup = drop the call. leave_message = play voicemailMessage as TTS, then hang up.
  voicemailBehavior  String            @default("hangup") // hangup | leave_message
  voicemailMessage   String?           // TTS text used when voicemailBehavior = leave_message
  // Skip answering-machine detection on power-dial legs. Default true because
  // AMD adds 4-7s of silence post-answer which is unacceptable in production
  // collections. With skipAmd, the customer leg goes straight from answer to
  // claim → bridge. Trade: agents handle voicemails manually (industry default
  // for collections power-dialers). voicemailBehavior + voicemailMessage are
  // only honoured when skipAmd=false.
  skipAmd            Boolean           @default(true)
  proximityMatchEnabled  Boolean           @default(true)
  autoRotateEnabled      Boolean           @default(true)
  maxCallsPerDIDPerDay   Int               @default(50)
  avoidRepeatDID         Boolean           @default(true)
  defaultDIDId           String?           // fallback DID if no proximity match
  retellAgentId             String?   // Retell agent ID (mirrors Retell's UI)
  retellSipAddress          String?   // Cached SIP URI, resolved from retellAgentId at campaign save
  createdById        String?
  createdBy          Profile?          @relation(fields: [createdById], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  lists              CampaignList[]
  contacts           CampaignContact[]
  attempts           CampaignAttempt[]
  callSessions       CallSession[]
  didGroups          CampaignDIDGroup[]
  powerDialBatches   PowerDialBatch[]

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

model CampaignList {
  id                 String            @id @default(uuid())
  campaignId         String
  campaign           Campaign          @relation(fields: [campaignId], references: [id])
  name               String
  sourceType         String            @default("upload") // upload | api | crm
  uploadStatus       String            @default("pending") // pending | imported | failed
  totalRecords       Int               @default(0)
  validRecords       Int               @default(0)
  duplicateSuppressed Int              @default(0)
  dncSuppressed      Int               @default(0)
  invalidRecords     Int               @default(0)
  createdAt          DateTime          @default(now())

  contacts           CampaignContact[]

  @@index([campaignId])
  @@index([createdAt])
}

model CampaignContact {
  id                 String            @id @default(uuid())
  campaignId         String
  campaign           Campaign          @relation(fields: [campaignId], references: [id])
  listId             String?
  list               CampaignList?     @relation(fields: [listId], references: [id])
  externalId         String?
  accountId          String?
  firstName          String?
  lastName           String?
  primaryPhone       String
  email              String?
  timezone           String?
  status             String            @default("queued") // queued | dialing | connected | completed | suppressed-dnc | failed
  priority           Int               @default(5)
  attemptCount       Int               @default(0)
  reservedByUserId   String?
  reservationType    String?
  reservationToken   String?
  reservationExpiresAt DateTime?
  lastAttemptAt      DateTime?
  nextAttemptAt      DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  attempts           CampaignAttempt[]
  callSessions       CallSession[]
  powerDialLegs      PowerDialLeg[]

  @@unique([campaignId, primaryPhone])
  @@index([campaignId, status])
  @@index([campaignId, reservationExpiresAt])
  @@index([listId])
  @@index([campaignId, priority, nextAttemptAt])
  @@index([status, nextAttemptAt])
}

model CampaignAttempt {
  id                 String            @id @default(uuid())
  campaignId         String
  campaign           Campaign          @relation(fields: [campaignId], references: [id])
  contactId          String
  contact            CampaignContact   @relation(fields: [contactId], references: [id])
  callId             String?
  call               Call?             @relation(fields: [callId], references: [id])
  outcome            String?           // human | voicemail | no-answer | busy | failed
  status             String            @default("initiated")
  startedAt          DateTime          @default(now())
  completedAt        DateTime?

  @@index([campaignId])
  @@index([contactId])
  @@index([callId])
  @@index([startedAt])
  @@index([campaignId, status, completedAt])
  @@index([campaignId, completedAt])
}

model DIDGroup {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  members     DIDGroupMember[]
  campaigns   CampaignDIDGroup[]
}

model DIDGroupMember {
  id      String      @id @default(uuid())
  groupId String
  group   DIDGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  phoneId String
  phone   PhoneNumber @relation(fields: [phoneId], references: [id], onDelete: Cascade)

  @@unique([groupId, phoneId])
  @@index([groupId])
  @@index([phoneId])
}

model CampaignDIDGroup {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  groupId    String
  group      DIDGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([campaignId, groupId])
  @@index([campaignId])
}

model AreaCodeMap {
  areaCode  String   @id
  state     String
  region    String
  city      String?
  latitude  Float?
  longitude Float?
  overlays  String?
  updatedAt DateTime @default(now())

  @@index([state])
  @@index([region])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// Power-dial Phase 2: tracks one dispatch tick's worth of parallel PSTN legs
// targeted at a single agent. The agent's /private/<targetRef> bridge gets the
// first AMD-confirmed-human leg via server-side claim. Other legs lose the race
// and either route to AI overflow or hang up (see PowerDialLeg.overflowTarget).
model PowerDialBatch {
  id           String   @id @default(uuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id])
  // Profile.id is UUID-typed (Supabase auth.users FK).
  agentId      String   @db.Uuid
  agent        Profile  @relation(fields: [agentId], references: [id])
  targetRef    String   // email local-part used for /private/<ref>
  legCount     Int
  status       String   @default("dispatching") // dispatching | claimed | exhausted
  claimedAt    DateTime?
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  legs         PowerDialLeg[]

  @@index([campaignId, status])
  @@index([agentId, status])
  @@index([expiresAt])
}

model PowerDialLeg {
  id              String   @id @default(uuid())
  batchId         String
  batch           PowerDialBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  contactId       String
  contact         CampaignContact @relation(fields: [contactId], references: [id])
  legIndex        Int
  providerCallId  String?
  status          String   @default("dialing") // dialing | rejected | machine | human-claimed | human-overflow | failed
  detectResult    String?  // human | machine | fax | unknown
  claimedAgent    Boolean  @default(false)
  overflowTarget  String?  // ai | hangup
  createdAt       DateTime @default(now())
  completedAt    DateTime?

  @@unique([batchId, legIndex])
  @@index([providerCallId])
  @@index([status])
}
