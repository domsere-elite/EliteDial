# ─── EliteDial Environment Configuration ───

# Backend
PORT=5000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h
NODE_ENV=development

# Database (Supabase PostgreSQL)
# Pooler URL (used by Prisma Client at runtime — transaction pooler, port 6543)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct URL (used by Prisma Migrate — bypasses pooler, port 5432)
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# SignalWire
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_API_TOKEN=
SIGNALWIRE_SPACE_URL=example.signalwire.com

# Frontend URL for CORS (set to deployed frontend URL in production)
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME=EliteDial
BACKEND_PUBLIC_URL=http://localhost:5000

# CRM Webhook (optional)
CRM_BASE_URL=
CRM_API_KEY=
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=

# Retell AI
RETELL_API_KEY=
RETELL_API_BASE_URL=https://api.retellai.com
RETELL_AGENT_ID=
RETELL_WEBHOOK_SECRET=
RETELL_DEFAULT_FROM_NUMBER=
RETELL_FALLBACK_NUMBER=

# Telephony defaults
DEFAULT_OUTBOUND_NUMBER=+15551000002
RECORDING_ARCHIVE_BASE_URL=
TRANSCRIPT_ARCHIVE_BASE_URL=

# Predictive dialer worker
DIALER_MODE=mock
DIALER_POLL_INTERVAL_MS=5000
